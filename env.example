# Database Configuration
DATABASE_URL="file:./prisma/data/dev.db"

# OpenAI Configuration (Required)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-openai-api-key"

# NextAuth Configuration (Required)
# For development, use http://localhost:3000
# For production, use your domain (e.g., https://your-domain.com)
NEXTAUTH_URL="http://localhost:3000"
# Generate a secure secret: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="your-nextauth-secret"

# Google OAuth Configuration (Optional)
# Set up OAuth app at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
NEXT_PUBLIC_GOOGLE_ENABLED="true"

# File Upload Configuration
# Local-disk fallback used when object storage (below) is not configured.
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="100000000"

# Object Storage (Tigris on Fly.io) — optional; local disk is used when unset.
# `fly storage create` sets all of these automatically on the Fly app.
# For local dev against a bucket, create an access key in the Tigris console.
# BUCKET_NAME="your-bucket"
# AWS_ENDPOINT_URL_S3="https://t3.storage.dev"
# AWS_ACCESS_KEY_ID="tid_..."
# AWS_SECRET_ACCESS_KEY="tsec_..."
# AWS_REGION="auto"
# S3_FORCE_PATH_STYLE only needed for MinIO in tests, not Tigris.
# S3_FORCE_PATH_STYLE="false"

# Pipeline worker (defaults shown)
# PIPELINE_WORKER_ENABLED="true"
# PIPELINE_POLL_INTERVAL_MS="5000"

# CORS Configuration
CORS_ORIGIN="http://localhost:3000"