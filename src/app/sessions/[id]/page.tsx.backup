'use client';

import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { useParams, useSearchParams } from 'next/navigation';
import Link from 'next/link';
import { useState, useRef, Suspense, useEffect } from 'react';
import { isNil } from 'lodash';
import {
  Calendar,
  Clock,
  BookOpen,
  FileText,
  Sparkles,
  ChevronDown,
  ChevronRight,
  Edit3,
  RefreshCw,
  CheckCircle,
  Save,
  Upload,
  AlertCircle,
  XCircle,
  Play,
  Loader2,
  Trash2,
  ChevronLeft,
  ChevronUp,
  Palette,
  Scroll,
  BookMarked,
  BookOpenCheck,
} from 'lucide-react';
import { marked } from 'marked';
import { logger } from '@/lib/logger';
import { cn } from '@/lib/utils';

// Theme types
type ThemeVariant = 'tome' | 'scroll' | 'grimoire' | 'codex';

interface ThemeConfig {
  name: string;
  icon: typeof BookOpen;
  description: string;
  colors: {
    background: string;
    surface: string;
    surfaceAlt: string;
    border: string;
    text: string;
    textMuted: string;
    accent: string;
    accentHover: string;
    processing: string;
    complete: string;
    error: string;
  };
  fonts: {
    heading: string;
    body: string;
  };
  effects: {
    paperTexture?: boolean;
    shadow?: string;
    borderStyle?: string;
  };
}

const themes: Record<ThemeVariant, ThemeConfig> = {
  tome: {
    name: 'Ancient Tome',
    icon: BookOpen,
    description: 'Classic leather-bound book with warm parchment',
    colors: {
      background: 'bg-amber-50',
      surface: 'bg-amber-100/80',
      surfaceAlt: 'bg-amber-50/90',
      border: 'border-amber-800/30',
      text: 'text-amber-950',
      textMuted: 'text-amber-800/70',
      accent: 'bg-amber-700',
      accentHover: 'hover:bg-amber-800',
      processing: 'text-amber-700',
      complete: 'text-emerald-700',
      error: 'text-red-700',
    },
    fonts: {
      heading: 'font-serif',
      body: 'font-serif',
    },
    effects: {
      paperTexture: true,
      shadow: 'shadow-2xl shadow-amber-900/20',
      borderStyle: 'border-2',
    },
  },
  scroll: {
    name: 'Parchment Scroll',
    icon: Scroll,
    description: 'Unrolled scroll with elegant script',
    colors: {
      background: 'bg-stone-50',
      surface: 'bg-stone-100/90',
      surfaceAlt: 'bg-stone-50/95',
      border: 'border-stone-600/25',
      text: 'text-stone-900',
      textMuted: 'text-stone-700/75',
      accent: 'bg-stone-600',
      accentHover: 'hover:bg-stone-700',
      processing: 'text-stone-600',
      complete: 'text-emerald-600',
      error: 'text-red-600',
    },
    fonts: {
      heading: 'font-serif',
      body: 'font-sans',
    },
    effects: {
      paperTexture: true,
      shadow: 'shadow-xl shadow-stone-800/15',
      borderStyle: 'border',
    },
  },
  grimoire: {
    name: 'Mystical Grimoire',
    icon: BookMarked,
    description: 'Dark magical tome with arcane symbols',
    colors: {
      background: 'bg-slate-900',
      surface: 'bg-slate-800/95',
      surfaceAlt: 'bg-slate-850/90',
      border: 'border-purple-500/30',
      text: 'text-slate-100',
      textMuted: 'text-slate-400',
      accent: 'bg-purple-600',
      accentHover: 'hover:bg-purple-700',
      processing: 'text-purple-400',
      complete: 'text-emerald-400',
      error: 'text-red-400',
    },
    fonts: {
      heading: 'font-serif',
      body: 'font-sans',
    },
    effects: {
      paperTexture: false,
      shadow: 'shadow-2xl shadow-purple-900/30',
      borderStyle: 'border',
    },
  },
  codex: {
    name: 'Illuminated Codex',
    icon: BookOpenCheck,
    description: 'Richly decorated manuscript with gold accents',
    colors: {
      background: 'bg-amber-100',
      surface: 'bg-yellow-50/95',
      surfaceAlt: 'bg-amber-50/90',
      border: 'border-amber-700/40',
      text: 'text-amber-950',
      textMuted: 'text-amber-900/65',
      accent: 'bg-amber-600',
      accentHover: 'hover:bg-amber-700',
      processing: 'text-amber-600',
      complete: 'text-emerald-600',
      error: 'text-red-600',
    },
    fonts: {
      heading: 'font-serif',
      body: 'font-serif',
    },
    effects: {
      paperTexture: true,
      shadow: 'shadow-2xl shadow-amber-800/25',
      borderStyle: 'border-2',
    },
  },
};

// Interfaces
interface Session {
  id: string;
  title: string;
  sessionDate: string;
  duration: number | null;
  status: string;
  campaign: {
    id: string;
    name: string;
  };
}

interface SessionDetail extends Session {
  uploadId: string | null;
  createdAt: string;
  currentStep: string | null;
  totalChunks: number | null;
  chunksCompleted: number | null;
  transcriptionProgress: number | null;
  errorStep: string | null;
  errorMessage: string | null;
  lastError: string | null;
  processingStartedAt: string | null;
  lastProgressAt: string | null;
  _count: {
    transcriptions: number;
  };
}

interface Summary {
  id: number;
  summaryText: string;
  createdAt: string;
  isEdited: boolean;
  editedAt: string | null;
}

interface DmTodoList {
  id: number;
  content: string;
  createdAt: string;
  isEdited: boolean;
  editedAt: string | null;
}

interface Transcription {
  id: number;
  text: string;
  startTime: number;
  endTime: number;
}

interface Upload {
  id: string;
  filename: string;
  originalName: string;
  size: number;
  duration: number | null;
  createdAt: string;
}

// Processing Step Component with Theme Support
function ProcessingStep({
  label,
  status,
  isActive,
  isLast,
  onStart,
  onCancel,
  progressPercent,
  minutesElapsed,
  isTimedOut,
  subStatus,
  theme,
}: {
  label: string;
  status: 'pending' | 'active' | 'complete' | 'error';
  isActive: boolean;
  isLast?: boolean;
  onStart?: () => void;
  onCancel?: () => void;
  progressPercent?: number;
  minutesElapsed?: number;
  isTimedOut?: boolean;
  subStatus?: string;
  theme: ThemeConfig;
}) {
  const IconComponent = theme.icon;
  
  return (
    <div className="flex items-center gap-3">
      <div className="flex flex-col items-center min-w-[120px]">
        <div
          className={`relative flex items-center justify-center w-14 h-14 rounded-full ${theme.effects.borderStyle} transition-all ${
            status === 'complete'
              ? `${theme.colors.complete} border-current ${theme.colors.surface}`
              : status === 'active'
              ? `${theme.colors.processing} border-current ${theme.colors.surface} animate-pulse`
              : status === 'error'
              ? `${theme.colors.error} border-current ${theme.colors.surface}`
              : `${theme.colors.border} ${theme.colors.surfaceAlt}`
          }`}
        >
          {status === 'complete' && (
            <CheckCircle className="w-7 h-7" />
          )}
          {status === 'active' && (
            <Loader2 className="w-7 h-7 animate-spin" />
          )}
          {status === 'error' && <XCircle className="w-7 h-7" />}
          {status === 'pending' && onStart && (
            <button
              onClick={onStart}
              className="w-full h-full flex items-center justify-center hover:opacity-80 rounded-full transition-opacity"
              title={`Start ${label}`}
            >
              <Play className="w-6 h-6" />
            </button>
          )}
          {status === 'pending' && !onStart && (
            <div className="w-3 h-3 rounded-full bg-current opacity-40" />
          )}
        </div>
        <div className={`mt-2 text-xs font-medium ${theme.colors.text}`}>
          {label}
        </div>
        {isActive && subStatus && (
          <div className={`mt-1 text-xs ${theme.colors.processing} text-center max-w-[140px]`}>
            {subStatus}
          </div>
        )}
        {isActive && progressPercent !== undefined && progressPercent > 0 && (
          <div className={`mt-1 text-xs ${theme.colors.textMuted}`}>
            {progressPercent}%
          </div>
        )}
        {isActive && isTimedOut && (
          <div className={`mt-1 text-xs ${theme.colors.error} font-semibold`}>
            ⚠️ {minutesElapsed}m
          </div>
        )}
        {isActive && onCancel && (
          <button
            onClick={onCancel}
            className={`mt-1 text-xs ${theme.colors.error} hover:opacity-80 font-medium transition-opacity`}
          >
            Cancel
          </button>
        )}
      </div>
      {!isLast && (
        <div
          className={`h-1 w-12 ${theme.effects.borderStyle} ${
            status === 'complete' ? theme.colors.complete : theme.colors.border
          }`}
        />
      )}
    </div>
  );
}

interface SessionToDelete {
  id: string;
  title: string;
  campaignId: string;
}

interface UIState {
  expandedSections: Set<string>;
  currentTheme: ThemeVariant;
}

interface EditingState {
  summary: {
    isEditing: boolean;
    text: string;
  };
  todo: {
    isEditing: boolean;
    text: string;
  };
}

interface UploadState {
  selectedFile: File | null;
  isUploading: boolean;
  showExistingUploads: boolean;
  linkingUploadId: string | null;
  error: string | null;
}

interface DeleteState {
  showModal: boolean;
  session: SessionToDelete | null;
}

function SessionPageContent() {
  const params = useParams();
  const sessionId = params.id as string;
  const searchParams = useSearchParams();
  const queryClient = useQueryClient();

  // Theme management
  const [currentTheme, setCurrentTheme] = useState<ThemeVariant>(() => {
    if (typeof window !== 'undefined') {
      const saved = localStorage.getItem('session-theme');
      if (saved && saved in themes) return saved as ThemeVariant;
    }
    return 'tome';
  });

  const theme = themes[currentTheme];

  const cycleTheme = () => {
    const themeKeys: ThemeVariant[] = ['tome', 'scroll', 'grimoire', 'codex'];
    const currentIndex = themeKeys.indexOf(currentTheme);
    const nextIndex = (currentIndex + 1) % themeKeys.length;
    const nextTheme = themeKeys[nextIndex];
    setCurrentTheme(nextTheme);
    if (typeof window !== 'undefined') {
      localStorage.setItem('session-theme', nextTheme);
    }
  };

  // Track if we just created this session with processing
  const initialState = searchParams.get('initialState');
  const isInitialProcessing = initialState === 'processing';
  const hasReceivedFirstData = useRef(false);

  // Consolidated state
  const [uiState, setUIState] = useState<UIState>({
    expandedSections: new Set(),
    currentTheme: 'tome',
  });

  const [editingState, setEditingState] = useState<EditingState>({
    summary: { isEditing: false, text: '' },
    todo: { isEditing: false, text: '' },
  });

  const [uploadState, setUploadState] = useState<UploadState>({
    selectedFile: null,
    isUploading: false,
    showExistingUploads: false,
    linkingUploadId: null,
    error: null,
  });

  const [deleteState, setDeleteState] = useState<DeleteState>({
    showModal: false,
    session: null,
  });

  // Data fetching (keeping existing queries)
  const { data: session, isLoading: sessionLoading } = useQuery<SessionDetail>({
    queryKey: ['session', sessionId],
    queryFn: async () => {
      const response = await fetch(`/api/sessions/${sessionId}`);
      if (!response.ok) throw new Error('Failed to fetch session');
      const data = await response.json();
      hasReceivedFirstData.current = true;
      return data;
    },
    refetchInterval: (query) => {
      const session = query.state.data;
      if (session?.status === 'transcribing' || session?.status === 'summarizing') {
        return 2000;
      }
      if (session?.status === 'uploaded') {
        return 1000;
      }
      if (session?.status === 'error') {
        return 5000;
      }
      return false;
    },
    refetchOnMount: true,
    staleTime: 0,
  });

  const { data: campaignSessions = [] } = useQuery<Session[]>({
    queryKey: ['campaign-sessions', session?.campaign.id],
    queryFn: async () => {
      const response = await fetch(
        `/api/sessions?campaignId=${session!.campaign.id}`
      );
      if (!response.ok) throw new Error('Failed to fetch campaign sessions');
      return response.json();
    },
    enabled: !!session?.campaign.id,
    refetchInterval: 10000,
  });

  const { data: summary } = useQuery<Summary>({
    queryKey: ['summary', sessionId],
    queryFn: async () => {
      const response = await fetch(`/api/summary/${sessionId}`);
      if (!response.ok) {
        if (response.status === 404) return null;
        throw new Error('Failed to fetch summary');
      }
      return response.json();
    },
    enabled: !!sessionId,
    refetchInterval: (query) => {
      if (session?.status === 'summarizing') return 2000;
      if (session?.status === 'transcribed' && !query.state.data) return 3000;
      return false;
    },
  });

  const { data: dmTodoList } = useQuery<DmTodoList>({
    queryKey: ['dmTodoList', sessionId],
    queryFn: async () => {
      const response = await fetch(`/api/dm-todo/${sessionId}`);
      if (!response.ok) {
        if (response.status === 404) return null;
        throw new Error('Failed to fetch TODO list');
      }
      return response.json();
    },
    enabled: !!sessionId,
    refetchInterval: (query) => {
      if (session?.status === 'summarizing') return 2000;
      if (summary && !query.state.data) return 3000;
      return false;
    },
  });

  const { data: transcriptions = [] } = useQuery<Transcription[]>({
    queryKey: ['transcriptions', sessionId],
    queryFn: async () => {
      const response = await fetch(`/api/sessions/${sessionId}/transcriptions`);
      if (!response.ok) {
        if (response.status === 404) return [];
        throw new Error('Failed to fetch transcriptions');
      }
      return response.json();
    },
    enabled: !!sessionId,
    refetchInterval: () => {
      if (session?.status === 'transcribing') return 2000;
      return false;
    },
  });

  const { data: uploads = [] } = useQuery<Upload[]>({
    queryKey: ['uploads'],
    queryFn: async () => {
      const response = await fetch('/api/uploads');
      if (!response.ok) throw new Error('Failed to fetch uploads');
      const data = await response.json();
      return data.uploads || [];
    },
    enabled: uploadState.showExistingUploads,
  });

  // Mutations (keeping existing mutations)
  const updateSummaryMutation = useMutation({
    mutationFn: async (summaryText: string) => {
      const response = await fetch(`/api/summary/${sessionId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ summary_text: summaryText }),
      });
      if (!response.ok) throw new Error('Failed to update summary');
      return response.json();
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['summary', sessionId] });
      setEditingState((prev) => ({
        ...prev,
        summary: { isEditing: false, text: '' },
      }));
    },
  });

  const updateTodoMutation = useMutation({
    mutationFn: async (content: string) => {
      const response = await fetch(`/api/dm-todo/${sessionId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content }),
      });
      if (!response.ok) throw new Error('Failed to update TODO');
      return response.json();
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['dmTodoList', sessionId] });
      setEditingState((prev) => ({
        ...prev,
        todo: { isEditing: false, text: '' },
      }));
    },
  });

  const generateSummaryMutation = useMutation({
    mutationFn: async () => {
      const response = await fetch(`/api/summary/${sessionId}`, {
        method: 'POST',
      });
      if (!response.ok) throw new Error('Failed to generate summary');
      return response.json();
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['summary', sessionId] });
    },
  });

  const generateTodoMutation = useMutation({
    mutationFn: async () => {
      const response = await fetch(`/api/dm-todo/${sessionId}`, {
        method: 'POST',
      });
      if (!response.ok) throw new Error('Failed to generate TODO');
      return response.json();
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['dmTodoList', sessionId] });
    },
  });

  const uploadAudioMutation = useMutation({
    mutationFn: async (file: File) => {
      setUploadState((prev) => ({ ...prev, isUploading: true, error: null }));

      const uploadFormData = new FormData();
      uploadFormData.append('audio', file);

      const uploadResponse = await fetch('/api/uploads', {
        method: 'POST',
        body: uploadFormData,
      });

      if (!uploadResponse.ok) {
        const error = await uploadResponse.json();
        throw new Error(error.error || 'Failed to upload file');
      }

      const uploadData = await uploadResponse.json();

      const linkResponse = await fetch(`/api/sessions/${sessionId}/upload`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          upload_id: uploadData.upload.id,
          duration: uploadData.upload.duration,
        }),
      });

      if (!linkResponse.ok) {
        const error = await linkResponse.json();
        throw new Error(error.error || 'Failed to link upload to session');
      }

      const processResponse = await fetch(
        `/api/sessions/${sessionId}/process`,
        {
          method: 'POST',
        }
      );

      if (!processResponse.ok) {
        logger.warn('Failed to trigger transcription, but upload was successful', { sessionId });
      }

      return linkResponse.json();
    },
    onSuccess: () => {
      setUploadState({
        selectedFile: null,
        isUploading: false,
        showExistingUploads: false,
        linkingUploadId: null,
        error: null,
      });
      queryClient.invalidateQueries({ queryKey: ['session', sessionId] });
      queryClient.invalidateQueries({
        queryKey: ['transcriptions', sessionId],
      });
    },
    onError: (error: Error) => {
      setUploadState((prev) => ({
        ...prev,
        isUploading: false,
        error: error.message,
      }));
    },
  });

  const linkExistingUploadMutation = useMutation({
    mutationFn: async (uploadId: string) => {
      setUploadState((prev) => ({
        ...prev,
        linkingUploadId: uploadId,
        error: null,
      }));

      const upload = uploads.find((u) => u.id === uploadId);

      const linkResponse = await fetch(`/api/sessions/${sessionId}/upload`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          upload_id: uploadId,
          duration: upload?.duration,
        }),
      });

      if (!linkResponse.ok) {
        const error = await linkResponse.json();
        throw new Error(
          error.details || error.error || 'Failed to link upload to session'
        );
      }

      const processResponse = await fetch(
        `/api/sessions/${sessionId}/process`,
        {
          method: 'POST',
        }
      );

      if (!processResponse.ok) {
        logger.warn('Failed to trigger transcription, but upload was linked successfully', { sessionId });
      }

      return linkResponse.json();
    },
    onSuccess: () => {
      setUploadState((prev) => ({
        ...prev,
        linkingUploadId: null,
        showExistingUploads: false,
        error: null,
      }));
      queryClient.invalidateQueries({ queryKey: ['session', sessionId] });
      queryClient.invalidateQueries({
        queryKey: ['transcriptions', sessionId],
      });
    },
    onError: (error: Error) => {
      setUploadState((prev) => ({
        ...prev,
        linkingUploadId: null,
        error: error.message,
      }));
    },
  });

  const cancelTranscriptionMutation = useMutation({
    mutationFn: async () => {
      const response = await fetch(`/api/transcription/${sessionId}`, {
        method: 'DELETE',
      });

      if (!response.ok) {
        const error = await response.json();
        throw new Error(
          error.error || 'Failed to cancel transcription'
        );
      }

      return response.json();
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['session', sessionId] });
      queryClient.invalidateQueries({
        queryKey: ['transcriptions', sessionId],
      });
    },
  });

  const startProcessingMutation = useMutation({
    mutationFn: async () => {
      const response = await fetch(`/api/sessions/${sessionId}/process`, {
        method: 'POST',
      });

      if (!response.ok) {
        const error = await response.json();
        throw new Error(
          error.details || error.error || 'Failed to start processing'
        );
      }

      return response.json();
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['session', sessionId] });
      queryClient.invalidateQueries({
        queryKey: ['transcriptions', sessionId],
      });
    },
  });

  const deleteSessionMutation = useMutation({
    mutationFn: async () => {
      if (!deleteState.session) throw new Error('No session selected for deletion');

      const response = await fetch(`/api/sessions/${deleteState.session.id}`, {
        method: 'DELETE',
      });

      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.error || 'Failed to delete session');
      }

      return response.json();
    },
    onSuccess: (data) => {
      if (deleteState.session?.id === sessionId) {
        window.location.href = `/campaigns/${data.campaignId}`;
      } else {
        queryClient.invalidateQueries({ queryKey: ['campaign-sessions', session?.campaign.id] });
        setDeleteState({ showModal: false, session: null });
      }
    },
  });

  // Handlers
  const toggleSection = (section: string) => {
    setUIState((prev) => {
      const next = new Set(prev.expandedSections);
      if (next.has(section)) {
        next.delete(section);
      } else {
        next.add(section);
      }
      return { ...prev, expandedSections: next };
    });
  };

  const handleEditSummary = () => {
    if (summary) {
      setEditingState((prev) => ({
        ...prev,
        summary: { isEditing: true, text: summary.summaryText },
      }));
    }
  };

  const handleSaveSummary = () => {
    updateSummaryMutation.mutate(editingState.summary.text);
  };

  const handleEditTodo = () => {
    if (dmTodoList) {
      setEditingState((prev) => ({
        ...prev,
        todo: { isEditing: true, text: dmTodoList.content },
      }));
    }
  };

  const handleSaveTodo = () => {
    updateTodoMutation.mutate(editingState.todo.text);
  };

  const formatDate = (dateString: string) => {
    return new Date(dateString).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  };

  const formatDuration = (minutes: number | null) => {
    if (!minutes) return 'Unknown';
    const hours = Math.floor(minutes / 60);
    const mins = minutes % 60;
    return hours > 0 ? `${hours}h ${mins}m` : `${mins}m`;
  };

  // Find current session index for navigation
  const currentSessionIndex = campaignSessions.findIndex(s => s.id === sessionId);
  const previousSession = currentSessionIndex > 0 ? campaignSessions[currentSessionIndex - 1] : null;
  const nextSession = currentSessionIndex < campaignSessions.length - 1 ? campaignSessions[currentSessionIndex + 1] : null;

  // Show optimistic loading state
  const showOptimisticProcessing = isInitialProcessing && !hasReceivedFirstData.current;

  if (sessionLoading || !session) {
    if (showOptimisticProcessing) {
      return (
        <div className={`flex flex-col h-screen overflow-hidden ${theme.colors.background}`}>
          <div className={`${theme.colors.surface} ${theme.effects.borderStyle} ${theme.colors.border} border-b`}>
            <div className="px-6 py-4">
              <div className="flex items-center justify-center gap-0">
                <ProcessingStep label="Upload" status="complete" isActive={false} theme={theme} />
                <ProcessingStep label="Transcribe" status="active" isActive={true} subStatus="Preparing..." theme={theme} />
                <ProcessingStep label="Summarize" status="pending" isActive={false} theme={theme} />
                <ProcessingStep label="Complete" status="pending" isActive={false} isLast={true} theme={theme} />
              </div>
            </div>
          </div>
          <div className="flex-1 overflow-auto p-6">
            <div className="max-w-5xl mx-auto space-y-4">
              <div className={`h-8 ${theme.colors.surfaceAlt} rounded animate-pulse w-1/3`}></div>
              <div className={`h-4 ${theme.colors.surfaceAlt} rounded animate-pulse w-1/4`}></div>
              <div className={`h-32 ${theme.colors.surfaceAlt} rounded animate-pulse mt-8`}></div>
            </div>
          </div>
        </div>
      );
    }

    return (
      <div className={`flex items-center justify-center min-h-screen ${theme.colors.background}`}>
        <Loader2 className={`w-12 h-12 ${theme.colors.processing} animate-spin`} />
      </div>
    );
  }

  const needsAudio = !session?.uploadId && transcriptions.length === 0;
  const hasError = session?.status === 'error';
  const isComplete = transcriptions.length > 0 && summary && dmTodoList;

  const processingTimedOut = session?.processingStartedAt
    ? (new Date().getTime() - new Date(session.processingStartedAt).getTime()) / (1000 * 60) > 30
    : false;

  const processingMinutesElapsed = session?.processingStartedAt
    ? Math.floor((new Date().getTime() - new Date(session.processingStartedAt).getTime()) / (1000 * 60))
    : 0;

  const hasUpload = !!session?.uploadId;
  const hasTranscription = transcriptions.length > 0;
  const hasSummary = !!summary;

  const getStepStatus = (step: 'upload' | 'transcribe' | 'summarize' | 'complete'): 'pending' | 'active' | 'complete' | 'error' => {
    if (hasError && (
      (step === 'transcribe' && session.errorStep?.includes('transcri')) ||
      (step === 'summarize' && session.errorStep?.includes('summar'))
    )) {
      return 'error';
    }

    switch (step) {
      case 'upload':
        return hasUpload ? 'complete' : 'pending';
      case 'transcribe':
        if (hasTranscription) return 'complete';
        if (session.status === 'transcribing') return 'active';
        if (isInitialProcessing && session.status === 'uploaded') return 'active';
        return hasUpload ? 'pending' : 'pending';
      case 'summarize':
        if (hasSummary) return 'complete';
        if (session.status === 'summarizing') return 'active';
        return hasTranscription ? 'pending' : 'pending';
      case 'complete':
        if (isComplete) return 'complete';
        return hasSummary ? 'pending' : 'pending';
    }
  };

  const getTranscriptionSubStatus = (): string | undefined => {
    if (isInitialProcessing && session.status === 'uploaded') {
      return 'Initializing...';
    }

    if (session.status !== 'transcribing') return undefined;

    const step = session.currentStep;
    const chunks = session.totalChunks;
    const completed = session.chunksCompleted;

    if (step === 'chunking') {
      return chunks ? `Creating ${chunks} chunks` : 'Checking audio...';
    }
    if (step === 'transcribing' && chunks && !isNil(completed)) {
      return `Chunk ${completed + 1}/${chunks}`;
    }
    if (step === 'stitching') {
      return 'Stitching...';
    }
    return 'Preparing...';
  };

  const ThemeIcon = theme.icon;

  return (
    <div className={`flex flex-col h-screen overflow-hidden ${theme.colors.background} transition-colors duration-300`}>
      {/* Theme Switcher - Fixed position */}
      <button
        onClick={cycleTheme}
        className={`fixed top-4 right-4 z-50 ${theme.colors.surface} ${theme.effects.borderStyle} ${theme.colors.border} ${theme.colors.text} px-4 py-2 rounded-lg ${theme.effects.shadow} hover:opacity-90 transition-all flex items-center gap-2 group`}
        title={`Current: ${theme.name} - Click to cycle themes`}
      >
        <ThemeIcon className="w-4 h-4" />
        <span className="text-sm font-medium hidden sm:inline">{theme.name}</span>
        <Palette className="w-4 h-4 opacity-60 group-hover:opacity-100 transition-opacity" />
      </button>

      {/* Processing Pipeline Header */}
      {!isComplete && (
        <div className={`${theme.colors.surface} ${theme.effects.borderStyle} ${theme.colors.border} border-b ${theme.effects.shadow}`}>
          <div className="px-6 py-5">
            <div className="flex items-center justify-center gap-0">
              <ProcessingStep
                label="Upload"
                status={getStepStatus('upload')}
                isActive={!hasUpload}
                theme={theme}
              />
              <ProcessingStep
                label="Transcribe"
                status={getStepStatus('transcribe')}
                isActive={session.status === 'transcribing' || (isInitialProcessing && session.status === 'uploaded')}
                onStart={hasUpload && !hasTranscription && session.status !== 'transcribing' && !(isInitialProcessing && session.status === 'uploaded') ? () => startProcessingMutation.mutate() : undefined}
                onCancel={session.status === 'transcribing' ? () => cancelTranscriptionMutation.mutate() : undefined}
                progressPercent={session.transcriptionProgress || undefined}
                minutesElapsed={session.status === 'transcribing' ? processingMinutesElapsed : undefined}
                isTimedOut={session.status === 'transcribing' && processingTimedOut}
                subStatus={getTranscriptionSubStatus()}
                theme={theme}
              />
              <ProcessingStep
                label="Summarize"
                status={getStepStatus('summarize')}
                isActive={session.status === 'summarizing'}
                onStart={hasTranscription && !hasSummary && session.status !== 'summarizing' ? () => startProcessingMutation.mutate() : undefined}
                theme={theme}
              />
              <ProcessingStep
                label="Complete"
                status={getStepStatus('complete')}
                isActive={false}
                isLast={true}
                theme={theme}
              />
            </div>
          </div>
        </div>
      )}

      {/* Upload Section */}
      {needsAudio && (
        <div className={`${theme.colors.surfaceAlt} ${theme.effects.borderStyle} ${theme.colors.border} border-b`}>
          <div className="px-6 py-4">
            <div className="flex items-start gap-4">
              <AlertCircle className={`h-6 w-6 ${theme.colors.error} flex-shrink-0 mt-1`} />
              <div className="flex-1">
                <h3 className={`text-lg font-semibold ${theme.colors.text} mb-2`}>
                  No Audio File
                </h3>
                <p className={`${theme.colors.textMuted} mb-4`}>
                  This session has no audio file attached. Upload an audio recording to generate transcriptions and AI summaries.
                </p>

                {uploadState.error && (
                  <div className={`mb-4 p-3 ${theme.colors.surfaceAlt} ${theme.effects.borderStyle} ${theme.colors.error} border rounded-lg`}>
                    <div className="flex items-start gap-2">
                      <AlertCircle className={`h-5 w-5 ${theme.colors.error} flex-shrink-0 mt-0.5`} />
                      <div className="flex-1">
                        <p className={`text-sm font-medium ${theme.colors.error}`}>
                          Upload Failed
                        </p>
                        <p className={`text-sm ${theme.colors.error} opacity-80 mt-1`}>
                          {uploadState.error}
                        </p>
                      </div>
                      <button
                        onClick={() =>
                          setUploadState((prev) => ({ ...prev, error: null }))
                        }
                        className={`${theme.colors.error} hover:opacity-80`}
                      >
                        ×
                      </button>
                    </div>
                  </div>
                )}

                <div className="space-y-3">
                  {!uploadState.showExistingUploads ? (
                    <>
                      <div className="flex items-center gap-3">
                        <input
                          type="file"
                          accept="audio/*"
                          onChange={(e) =>
                            setUploadState((prev) => ({
                              ...prev,
                              selectedFile: e.target.files?.[0] || null,
                            }))
                          }
                          className={`block text-sm ${theme.colors.text} file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold ${theme.colors.accent} file:text-white ${theme.colors.accentHover} file:cursor-pointer`}
                          disabled={uploadState.isUploading}
                        />
                        {uploadState.selectedFile && (
                          <button
                            onClick={() =>
                              uploadAudioMutation.mutate(uploadState.selectedFile!)
                            }
                            disabled={uploadState.isUploading}
                            className={`px-4 py-2 ${theme.colors.accent} text-white rounded-lg ${theme.colors.accentHover} disabled:opacity-50 flex items-center gap-2`}
                          >
                            {uploadState.isUploading ? (
                              <>
                                <RefreshCw className="h-4 w-4 animate-spin" />
                                Uploading...
                              </>
                            ) : (
                              <>
                                <Upload className="h-4 w-4" />
                                Upload & Process
                              </>
                            )}
                          </button>
                        )}
                      </div>
                      <p className={`text-sm ${theme.colors.textMuted}`}>
                        Or{' '}
                        <button
                          onClick={() =>
                            setUploadState((prev) => ({
                              ...prev,
                              showExistingUploads: true,
                            }))
                          }
                          className="underline hover:opacity-80 font-medium"
                        >
                          link an existing upload
                        </button>
                      </p>
                    </>
                  ) : (
                    <div className="space-y-2">
                      <div className="flex items-center justify-between mb-3">
                        <h4 className={`text-sm font-semibold ${theme.colors.text}`}>
                          Select an Upload
                        </h4>
                        <button
                          onClick={() =>
                            setUploadState((prev) => ({
                              ...prev,
                              showExistingUploads: false,
                            }))
                          }
                          className={`text-sm ${theme.colors.textMuted} hover:opacity-80`}
                        >
                          Cancel
                        </button>
                      </div>
                      {uploads.length === 0 ? (
                        <p className={`text-sm ${theme.colors.textMuted}`}>
                          No existing uploads found.
                        </p>
                      ) : (
                        <div className={`max-h-64 overflow-y-auto space-y-2 ${theme.effects.borderStyle} ${theme.colors.border} rounded-lg p-2 ${theme.colors.surface}`}>
                          {uploads.map((upload) => (
                            <button
                              key={upload.id}
                              onClick={() =>
                                linkExistingUploadMutation.mutate(upload.id)
                              }
                              disabled={uploadState.linkingUploadId === upload.id}
                              className={`w-full text-left p-3 ${theme.colors.surfaceAlt} rounded-lg ${theme.effects.borderStyle} ${theme.colors.border} hover:opacity-80 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed`}
                            >
                              <div className="flex items-center justify-between">
                                <div className="flex-1 min-w-0">
                                  <p className={`text-sm font-medium ${theme.colors.text} truncate`}>
                                    {upload.originalName}
                                  </p>
                                  <div className={`flex items-center gap-2 mt-1 text-xs ${theme.colors.textMuted}`}>
                                    <span>
                                      {(upload.size / 1024 / 1024).toFixed(2)} MB
                                    </span>
                                    {upload.duration && (
                                      <span>
                                        • {Math.floor(upload.duration / 60)}m {upload.duration % 60}s
                                      </span>
                                    )}
                                  </div>
                                </div>
                                {uploadState.linkingUploadId === upload.id ? (
                                  <RefreshCw className={`h-4 w-4 ${theme.colors.processing} animate-spin flex-shrink-0 ml-2`} />
                                ) : (
                                  <CheckCircle className={`h-4 w-4 ${theme.colors.textMuted} flex-shrink-0 ml-2`} />
                                )}
                              </div>
                            </button>
                          ))}
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Error Banner */}
      {hasError && session.errorMessage && (
        <div className={`${theme.colors.surfaceAlt} ${theme.effects.borderStyle} ${theme.colors.error} border-b`}>
          <div className="px-6 py-3">
            <div className="flex items-start gap-3">
              <AlertCircle className={`h-5 w-5 ${theme.colors.error} flex-shrink-0 mt-0.5`} />
              <div className="flex-1">
                <p className={`text-sm font-medium ${theme.colors.error}`}>
                  {session.errorStep?.includes('timeout')
                    ? 'Processing Timeout'
                    : 'Error during ' + (session.errorStep || 'processing')}
                </p>
                <p className={`text-sm ${theme.colors.error} opacity-80 mt-1`}>
                  {session.errorMessage}
                </p>
              </div>
              <button
                onClick={() => startProcessingMutation.mutate()}
                disabled={startProcessingMutation.isPending}
                className={`px-3 py-1.5 text-sm ${theme.colors.accent} text-white rounded-lg ${theme.colors.accentHover} disabled:opacity-50 flex items-center gap-2`}
              >
                {startProcessingMutation.isPending ? (
                  <>
                    <RefreshCw className="h-4 w-4 animate-spin" />
                    Retrying...
                  </>
                ) : (
                  <>
                    <RefreshCw className="h-4 w-4" />
                    Retry
                  </>
                )}
              </button>
            </div>
          </div>
        </div>
      )}

      {/* Main Content Layout */}
      <div className="flex flex-1 overflow-hidden">
        {/* Left Sidebar - Campaign Navigation */}
        <aside className={`w-80 ${theme.colors.surface} ${theme.effects.borderStyle} ${theme.colors.border} border-r flex flex-col ${theme.effects.shadow}`}>
          <div className={`p-4 ${theme.effects.borderStyle} ${theme.colors.border} border-b`}>
            <Link
              href={`/campaigns/${session.campaign.id}`}
              className={cn('flex items-center gap-2 text-sm mb-3 transition-colors hover:opacity-80', theme.colors.textMuted)}
            >
              <BookOpen className="h-4 w-4" />
              <span className="font-medium">{session.campaign.name}</span>
            </Link>
            <div className={`text-xs ${theme.colors.textMuted}`}>
              {campaignSessions.length} session{campaignSessions.length !== 1 ? 's' : ''} in campaign
            </div>
          </div>

          {/* Session Navigation */}
          <div className="flex-1 overflow-y-auto p-3">
            <div className={`text-xs font-semibold ${theme.colors.textMuted} uppercase px-2 mb-3`}>
              All Sessions
            </div>
            
            {/* Previous/Next Quick Nav */}
            {(previousSession || nextSession) && (
              <div className="flex gap-2 mb-4 px-2">
                {previousSession && (
                  <Link
                    href={`/sessions/${previousSession.id}`}
                    className={`flex-1 px-3 py-2 ${theme.colors.surfaceAlt} ${theme.effects.borderStyle} ${theme.colors.border} rounded-lg hover:opacity-80 transition-opacity flex items-center gap-2 text-sm ${theme.colors.text}`}
                  >
                    <ChevronLeft className="w-4 h-4" />
                    <span className="truncate">{previousSession.title}</span>
                  </Link>
                )}
                {nextSession && (
                  <Link
                    href={`/sessions/${nextSession.id}`}
                    className={`flex-1 px-3 py-2 ${theme.colors.surfaceAlt} ${theme.effects.borderStyle} ${theme.colors.border} rounded-lg hover:opacity-80 transition-opacity flex items-center gap-2 text-sm ${theme.colors.text}`}
                  >
                    <span className="truncate">{nextSession.title}</span>
                    <ChevronRight className="w-4 h-4" />
                  </Link>
                )}
              </div>
            )}

            {campaignSessions.map((s) => (
              <div
                key={s.id}
                className={cn(
                  'group relative rounded-lg mb-2 transition-all',
                  theme.effects.borderStyle,
                  s.id === sessionId
                    ? cn(theme.colors.accent, theme.colors.text, 'border-current', theme.effects.shadow, 'py-4')
                    : cn(theme.colors.border, 'border-transparent hover:opacity-80', theme.colors.text, 'py-3')
                )}
              >
                <Link href={`/sessions/${s.id}`} className="block px-4">
                  <div
                    className={`mb-2 ${s.id === sessionId ? 'text-base font-bold' : 'text-sm font-medium'}`}
                  >
                    {s.title}
                  </div>
                  <div className={`flex flex-wrap gap-x-3 gap-y-1 text-xs ${theme.colors.textMuted}`}>
                    <div className="flex items-center gap-1">
                      <Calendar className="h-3 w-3" />
                      <span>
                        {new Date(s.sessionDate).toLocaleDateString('en-US', {
                          month: 'short',
                          day: 'numeric',
                        })}
                      </span>
                    </div>
                    {s.duration && (
                      <div className="flex items-center gap-1">
                        <Clock className="h-3 w-3" />
                        <span>{formatDuration(s.duration)}</span>
                      </div>
                    )}
                    <div
                      className={`px-2 py-0.5 rounded text-xs font-medium ${theme.colors.surfaceAlt} ${theme.colors.text}`}
                    >
                      {s.status}
                    </div>
                  </div>
                </Link>
                <button
                  onClick={(e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    setDeleteState({
                      showModal: true,
                      session: {
                        id: s.id,
                        title: s.title,
                        campaignId: s.campaign.id,
                      },
                    });
                  }}
                  className={cn('absolute top-2 right-2 p-1.5 rounded opacity-0 group-hover:opacity-100 hover:opacity-100 transition-opacity', theme.colors.textMuted, 'hover:text-red-600')}
                  title="Delete session"
                >
                  <Trash2 className="h-3.5 w-3.5" />
                </button>
              </div>
            ))}
          </div>
        </aside>

        {/* Main Content Area */}
        <main className={`flex-1 overflow-y-auto ${theme.colors.surface}`}>
          {/* Session Header */}
          <div className={`${theme.effects.borderStyle} ${theme.colors.border} border-b ${theme.colors.surfaceAlt}`}>
            <div className="px-8 py-6 flex items-center justify-between">
              <div>
                <h1 className={`text-3xl font-bold ${theme.colors.text} ${theme.fonts.heading}`}>
                  {session.title}
                </h1>
                <div className={`flex items-center gap-4 mt-2 text-sm ${theme.colors.textMuted}`}>
                  <div className="flex items-center gap-1">
                    <Calendar className="h-4 w-4" />
                    <span>
                      {new Date(session.sessionDate).toLocaleDateString('en-US', {
                        weekday: 'long',
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </span>
                  </div>
                  {session.duration && (
                    <div className="flex items-center gap-1">
                      <Clock className="h-4 w-4" />
                      <span>{formatDuration(session.duration)}</span>
                    </div>
                  )}
                </div>
              </div>
              <button
                onClick={() => {
                  setDeleteState({
                    showModal: true,
                    session: {
                      id: session.id,
                      title: session.title,
                      campaignId: session.campaign.id,
                    },
                  });
                }}
                className={`px-3 py-2 text-sm ${theme.colors.error} ${theme.effects.borderStyle} ${theme.colors.error} border rounded-lg hover:opacity-80 flex items-center gap-2`}
              >
                <Trash2 className="h-4 w-4" />
                Delete Session
              </button>
            </div>
          </div>

          {/* Summary Section */}
          <div className={`${theme.effects.borderStyle} ${theme.colors.border} border-b`}>
            <div className={`${theme.colors.surface} p-8 ${theme.effects.paperTexture ? 'bg-[url("data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23000000\' fill-opacity=\'0.02\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")]' : ''}`}>
              <div className={`flex items-center justify-between mb-6 pb-4 ${theme.effects.borderStyle} ${theme.colors.border} border-b-2`}>
                <div className="flex items-center gap-3">
                  <Sparkles className={`h-7 w-7 ${theme.colors.accent}`} />
                  <h2 className={`text-2xl font-bold ${theme.colors.text} ${theme.fonts.heading}`}>
                    AI Summary
                  </h2>
                </div>
                <div className="flex gap-2">
                  {summary && (
                    <>
                      {!editingState.summary.isEditing && (
                        <button
                          onClick={handleEditSummary}
                          className={`px-3 py-2 text-sm ${theme.colors.text} ${theme.effects.borderStyle} ${theme.colors.border} rounded-lg hover:opacity-80 flex items-center gap-2`}
                        >
                          <Edit3 className="h-4 w-4" />
                          Edit
                        </button>
                      )}
                      <button
                        onClick={() => generateSummaryMutation.mutate()}
                        disabled={generateSummaryMutation.isPending}
                        className={`px-3 py-2 text-sm ${theme.colors.text} ${theme.effects.borderStyle} ${theme.colors.border} rounded-lg hover:opacity-80 flex items-center gap-2`}
                      >
                        <RefreshCw
                          className={`h-4 w-4 ${generateSummaryMutation.isPending ? 'animate-spin' : ''}`}
                        />
                        Regenerate
                      </button>
                    </>
                  )}
                </div>
              </div>

              {summary ? (
                editingState.summary.isEditing ? (
                  <div className="space-y-4">
                    <textarea
                      value={editingState.summary.text}
                      onChange={(e) =>
                        setEditingState((prev) => ({
                          ...prev,
                          summary: { ...prev.summary, text: e.target.value },
                        }))
                      }
                      className={`w-full h-64 p-4 ${theme.effects.borderStyle} ${theme.colors.border} rounded-lg resize-none focus:outline-none focus:ring-2 ${theme.colors.accent} ${theme.colors.surfaceAlt} ${theme.colors.text}`}
                    />
                    <div className="flex justify-end gap-2">
                      <button
                        onClick={() =>
                          setEditingState((prev) => ({
                            ...prev,
                            summary: { isEditing: false, text: '' },
                          }))
                        }
                        className={`px-4 py-2 text-sm ${theme.colors.text} ${theme.effects.borderStyle} ${theme.colors.border} rounded-lg hover:opacity-80`}
                      >
                        Cancel
                      </button>
                      <button
                        onClick={handleSaveSummary}
                        disabled={updateSummaryMutation.isPending}
                        className={`px-4 py-2 text-sm text-white ${theme.colors.accent} rounded-lg ${theme.colors.accentHover} flex items-center gap-2`}
                      >
                        <Save className="h-4 w-4" />
                        {updateSummaryMutation.isPending ? 'Saving...' : 'Save'}
                      </button>
                    </div>
                  </div>
                ) : (
                  <div className="prose prose-slate max-w-none">
                    <div className={`${theme.colors.text} leading-relaxed text-base max-h-96 overflow-y-auto pr-4 custom-scrollbar ${theme.fonts.body}`}>
                      {summary.summaryText}
                    </div>
                    {summary.isEdited && summary.editedAt && (
                      <p className={`text-xs ${theme.colors.textMuted} mt-4 italic`}>
                        Edited {formatDate(summary.editedAt)}
                      </p>
                    )}
                  </div>
                )
              ) : (
                <div className="text-center py-12">
                  <Sparkles className={`h-12 w-12 ${theme.colors.textMuted} mx-auto mb-3`} />
                  <p className={`${theme.colors.textMuted} mb-4`}>No summary generated yet</p>
                  {transcriptions.length > 0 && (
                    <button
                      onClick={() => generateSummaryMutation.mutate()}
                      disabled={generateSummaryMutation.isPending}
                      className={`px-4 py-2 text-white ${theme.colors.accent} rounded-lg ${theme.colors.accentHover}`}
                    >
                      {generateSummaryMutation.isPending
                        ? 'Generating...'
                        : 'Generate Summary'}
                    </button>
                  )}
                </div>
              )}
            </div>

            {/* Transcript Section */}
            <div className={`${theme.effects.borderStyle} ${theme.colors.border} border-t`}>
              <button
                onClick={() => toggleSection('transcript')}
                className={cn('w-full px-8 py-4 flex items-center justify-between hover:opacity-80 transition-colors', theme.colors.text)}
              >
                <div className="flex items-center gap-3">
                  <FileText className={`h-5 w-5 ${theme.colors.textMuted}`} />
                  <span className={`font-semibold ${theme.colors.text}`}>
                    Full Transcript
                  </span>
                  <span className={`text-sm ${theme.colors.textMuted}`}>
                    ({transcriptions.length} segments)
                  </span>
                </div>
                {uiState.expandedSections.has('transcript') ? (
                  <ChevronDown className={`h-5 w-5 ${theme.colors.textMuted}`} />
                ) : (
                  <ChevronRight className={`h-5 w-5 ${theme.colors.textMuted}`} />
                )}
              </button>
              {uiState.expandedSections.has('transcript') && (
                <div className={`px-8 py-6 ${theme.colors.surfaceAlt} ${theme.effects.borderStyle} ${theme.colors.border} border-t max-h-96 overflow-y-auto space-y-4`}>
                  {transcriptions.map((t) => (
                    <div
                      key={t.id}
                      className={`${theme.colors.surface} p-4 ${theme.effects.borderStyle} ${theme.colors.accent} border-l-4`}
                    >
                      <div className={`text-xs ${theme.colors.textMuted} mb-2`}>
                        {Math.floor(t.startTime / 60)}:
                        {String(Math.floor(t.startTime % 60)).padStart(2, '0')}{' '}
                        -{Math.floor(t.endTime / 60)}:
                        {String(Math.floor(t.endTime % 60)).padStart(2, '0')}
                      </div>
                      <p className={theme.colors.text}>{t.text}</p>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        </main>

        {/* Right Panel - TODO List */}
        <aside className={`w-96 ${theme.colors.surface} ${theme.effects.borderStyle} ${theme.colors.border} border-l overflow-y-auto flex-shrink-0 ${theme.effects.shadow}`}>
          <div className={`sticky top-0 ${theme.colors.surface} p-6 ${theme.effects.borderStyle} ${theme.colors.border} border-b`}>
            <div className="flex items-center gap-2 mb-2">
              <CheckCircle className={`h-6 w-6 ${theme.colors.accent}`} />
              <h2 className={`text-xl font-bold ${theme.colors.text} ${theme.fonts.heading}`}>DM Prep TODO</h2>
            </div>
            <div className="flex gap-2 mt-4">
              {dmTodoList && !editingState.todo.isEditing && (
                <button
                  onClick={handleEditTodo}
                  className={`px-3 py-1 text-xs ${theme.colors.text} ${theme.effects.borderStyle} ${theme.colors.border} rounded hover:opacity-80`}
                >
                  <Edit3 className="h-3 w-3 inline mr-1" />
                  Edit
                </button>
              )}
              <button
                onClick={() => generateTodoMutation.mutate()}
                disabled={generateTodoMutation.isPending}
                className={`px-3 py-1 text-xs ${theme.colors.text} ${theme.effects.borderStyle} ${theme.colors.border} rounded hover:opacity-80`}
              >
                <RefreshCw
                  className={`h-3 w-3 inline mr-1 ${generateTodoMutation.isPending ? 'animate-spin' : ''}`}
                />
                {dmTodoList ? 'Regenerate' : 'Generate'}
              </button>
            </div>
          </div>

          <div className={`p-6 ${theme.effects.paperTexture ? 'bg-[url("data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23000000\' fill-opacity=\'0.02\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")]' : ''}`}>
            {dmTodoList ? (
              editingState.todo.isEditing ? (
                <div className="space-y-4">
                  <textarea
                    value={editingState.todo.text}
                    onChange={(e) =>
                      setEditingState((prev) => ({
                        ...prev,
                        todo: { ...prev.todo, text: e.target.value },
                      }))
                    }
                    className={`w-full h-96 p-4 ${theme.effects.borderStyle} ${theme.colors.border} rounded-lg resize-none focus:outline-none focus:ring-2 ${theme.colors.accent} font-mono text-sm ${theme.colors.surfaceAlt} ${theme.colors.text}`}
                  />
                  <div className="flex gap-2">
                    <button
                      onClick={() =>
                        setEditingState((prev) => ({
                          ...prev,
                          todo: { isEditing: false, text: '' },
                        }))
                      }
                      className={`flex-1 px-3 py-2 text-sm ${theme.colors.text} ${theme.effects.borderStyle} ${theme.colors.border} rounded hover:opacity-80`}
                    >
                      Cancel
                    </button>
                    <button
                      onClick={handleSaveTodo}
                      disabled={updateTodoMutation.isPending}
                      className={`flex-1 px-3 py-2 text-sm text-white ${theme.colors.accent} rounded ${theme.colors.accentHover}`}
                    >
                      {updateTodoMutation.isPending ? 'Saving...' : 'Save'}
                    </button>
                  </div>
                </div>
              ) : (
                <div
                  className={`prose prose-sm prose-slate max-w-none ${theme.fonts.body}`}
                  dangerouslySetInnerHTML={{
                    __html: marked(dmTodoList.content) as string,
                  }}
                />
              )
            ) : (
              <div className="text-center py-12">
                <CheckCircle className={`h-12 w-12 ${theme.colors.textMuted} mx-auto mb-3`} />
                <p className={`${theme.colors.textMuted} mb-4`}>No TODO list yet</p>
                {transcriptions.length > 0 && (
                  <button
                    onClick={() => generateTodoMutation.mutate()}
                    disabled={generateTodoMutation.isPending}
                    className={`px-4 py-2 text-white ${theme.colors.accent} rounded-lg ${theme.colors.accentHover}`}
                  >
                    {generateTodoMutation.isPending
                      ? 'Generating...'
                      : 'Generate TODO'}
                  </button>
                )}
              </div>
            )}
          </div>
        </aside>
      </div>

      {/* Delete Confirmation Modal */}
      {deleteState.showModal && deleteState.session && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
          <div className={`${theme.colors.surface} rounded-lg p-6 max-w-md w-full mx-4 ${theme.effects.shadow}`}>
            <div className="flex items-start gap-4">
              <div className={`flex-shrink-0 w-10 h-10 rounded-full ${theme.colors.error} bg-opacity-20 flex items-center justify-center`}>
                <Trash2 className={`h-5 w-5 ${theme.colors.error}`} />
              </div>
              <div className="flex-1">
                <h3 className={`text-lg font-semibold ${theme.colors.text} mb-2`}>
                  Delete Session
                </h3>
                <p className={`text-sm ${theme.colors.textMuted} mb-4`}>
                  Are you sure you want to delete &quot;{deleteState.session.title}&quot;? This action cannot be undone and will permanently delete:
                </p>
                <ul className={`text-sm ${theme.colors.textMuted} list-disc list-inside space-y-1 mb-4`}>
                  <li>All transcriptions</li>
                  <li>AI-generated summary</li>
                  <li>DM TODO list</li>
                  <li>Session metadata</li>
                </ul>
                <p className={`text-sm ${theme.colors.textMuted} italic`}>
                  Note: The uploaded audio file will not be deleted and can be reused.
                </p>
              </div>
            </div>
            <div className="flex gap-3 mt-6">
              <button
                onClick={() => {
                  setDeleteState({ showModal: false, session: null });
                }}
                disabled={deleteSessionMutation.isPending}
                className={`flex-1 px-4 py-2 text-sm font-medium ${theme.colors.text} ${theme.colors.surfaceAlt} ${theme.effects.borderStyle} ${theme.colors.border} rounded-lg hover:opacity-80 disabled:opacity-50`}
              >
                Cancel
              </button>
              <button
                onClick={() => deleteSessionMutation.mutate()}
                disabled={deleteSessionMutation.isPending}
                className={`flex-1 px-4 py-2 text-sm font-medium text-white ${theme.colors.error} rounded-lg hover:opacity-90 disabled:opacity-50 flex items-center justify-center gap-2`}
              >
                {deleteSessionMutation.isPending ? (
                  <>
                    <RefreshCw className="h-4 w-4 animate-spin" />
                    Deleting...
                  </>
                ) : (
                  <>
                    <Trash2 className="h-4 w-4" />
                    Delete Session
                  </>
                )}
              </button>
            </div>
          </div>
        </div>
      )}

      <style jsx global>{`
        .custom-scrollbar::-webkit-scrollbar {
          width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
          background: rgba(0, 0, 0, 0.2);
          border-radius: 3px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
          background: transparent;
        }
      `}</style>
    </div>
  );
}

export default function SessionPage() {
  return (
    <Suspense fallback={
      <div className="flex items-center justify-center min-h-screen bg-amber-50">
        <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-amber-600"></div>
      </div>
    }>
      <SessionPageContent />
    </Suspense>
  );
}